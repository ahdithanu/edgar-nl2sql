# Copy to .env and fill in real values. Never commit .env.

# Supabase Postgres connection string (use the *pooler* URL, port 6543, for app traffic).
# Format: postgresql://USER:PASSWORD@HOST:6543/postgres
DATABASE_URL=

# Anthropic API key — used for SQL generation and answer synthesis.
ANTHROPIC_API_KEY=

# Voyage AI API key — used for embedding the RAG corpus and incoming questions.
VOYAGE_API_KEY=

# Claude model for SQL generation (optional; defaults to claude-sonnet-5).
CLAUDE_MODEL=claude-sonnet-5

# Log verbosity for structlog JSON output (optional; defaults to INFO).
LOG_LEVEL=INFO

# --- API protection (set QUERY_API_KEY for any public deployment) ---
# If set, POST /query requires a matching X-API-Key header (401 otherwise).
# QUERY_API_KEY=
# Per-client-IP requests/minute cap on POST /query; 0 disables. Default 30.
# RATE_LIMIT_PER_MINUTE=30

# --- Optional tuning knobs (defaults shown; uncomment to override) ---
# Voyage embedding model — must stay 1024-dim to match VECTOR(1024) in schema.sql.
# EMBED_MODEL=voyage-3.5-lite
# Context documents retrieved per question.
# RETRIEVAL_TOP_K=8
# Hard cap on rows returned to the client / fed to the LLM.
# MAX_RESULT_ROWS=200
# Server-side kill switch for runaway generated SQL, in milliseconds.
# STATEMENT_TIMEOUT_MS=10000
